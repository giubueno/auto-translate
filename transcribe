#!/bin/bash

####################################################################################################
# This script transcribes an MP3 file using AWS Transcribe service
# and saves the transcription result to a JSON file.
####################################################################################################

# Check if the necessary arguments are provided
if [ "$#" -ne 3 ]; then
    echo "Usage: $0 <input_file.mp3> <output_file.json> <s3_bucket>"
    exit 1
fi

# Assign input and output file names
input_file=$1
output_file=$2
s3_bucket=$3

# Get the default region from AWS configuration
region=$(aws configure get region)

# Transcribe the MP3 file using AWS Transcribe
aws transcribe start-transcription-job \
    --region $region \
    --language-code en-US \
    --media MediaFileUri="s3://$s3_bucket/$input_file" \
    --output-bucket $s3_bucket \
    --output-key $output_file \
    --transcription-job-name transcribe-job-$(date +%s)

# Check if transcription job started successfully
if [ $? -eq 0 ]; then
    echo "Transcription job started successfully."
else
    echo "Failed to start transcription job."
    exit 1
fi

# Wait until transcription job is completed
while true; do
    status=$(aws transcribe get-transcription-job --region $region --transcription-job-name transcribe-job-$(date +%s) --query 'TranscriptionJob.TranscriptionJobStatus' --output text)
    if [ "$status" == "COMPLETED" ]; then
        echo "Transcription completed successfully."
        break
    elif [ "$status" == "FAILED" ]; then
        echo "Transcription failed."
        exit 1
    else
        echo "Transcription job is still in progress..."
        sleep 10
    fi
done

# Retrieve the transcription result
aws s3 cp s3://$s3_bucket/$output_file .

# Check if transcription result is downloaded successfully
if [ $? -eq 0 ]; then
    echo "Transcription result saved to $output_file"
    exit 0
else
    echo "Failed to download transcription result."
    exit 1
fi

